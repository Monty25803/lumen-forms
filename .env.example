# Copy to .env and adjust for your environment.
DJANGO_SECRET_KEY=replace-me-with-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Google OAuth (required for Sign-in + Sheets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

LUMEN_SITE_NAME=Lumen
LUMEN_SITE_TAGLINE=Sign in with Google. Build a form. Answers land in your Sheet.
LUMEN_SUBMISSION_RATE_LIMIT=20
LUMEN_SUBMISSION_RATE_WINDOW=3600
LUMEN_NOTIFY_OWNER_ON_RESPONSE=true

# Optional SMTP (defaults to console email in development)
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=Lumen <noreply@yourdomain.com>
